# LMS AppSec — пример конфигурации
# Скопируйте в .env и замените значения перед запуском:
#   cp .env.example .env

# PostgreSQL
POSTGRES_USER=lms
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=lms
DATABASE_URL=postgresql+asyncpg://lms:CHANGE_ME@postgres:5432/lms

# JWT — сгенерировать: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Домен (Traefik routing)
DOMAIN=lab.local
TRAEFIK_NETWORK=lms_network

# GitLab (опционально — только если используются GitLab-задания)
# GITLAB_URL=https://gitlab.example.com
# GITLAB_ADMIN_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
